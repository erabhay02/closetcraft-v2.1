{
  "expo": {
    "name": "ClosetCraft",
    "slug": "closetcraft",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.closetcraft.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "ClosetCraft uses the camera to measure your closet walls using AR technology.",
        "NSPhotoLibraryUsageDescription": "ClosetCraft saves your closet designs to your photo library."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.closetcraft.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "ClosetCraft uses the camera to measure your closet walls."
        }
      ]
    ]
  }
}